# Copy this file to `.env` and fill in the two values from your Supabase project:
# Supabase dashboard -> Project Settings -> API
# (These are safe to expose in the browser; the service-role key must NEVER go here.)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Cloudflare Turnstile (CAPTCHA) — used on signup/login/reset-password and the
# "generate AI report" button on enhancement requests. Leave unset in local dev:
# the widget simply won't render and those flows behave as if captcha weren't
# wired up. Get a site key: dash.cloudflare.com -> Turnstile -> Add site.
VITE_TURNSTILE_SITE_KEY=
