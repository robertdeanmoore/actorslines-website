# Copy this file to `.env` and fill in the two values from your Supabase project:
# Supabase dashboard -> Project Settings -> API
# (These are safe to expose in the browser; the service-role key must NEVER go here.)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
